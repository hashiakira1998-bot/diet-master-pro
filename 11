import React, { useState, useRef, useEffect, useMemo, useCallback } from "react";

/* ==========================================
   1. Constants & Global Styles
========================================== */
const LS_KEY = "dlp_state";

const GLOBAL_CSS = `
  *{box-sizing:border-box;margin:0;padding:0}
  html{height:100%;-webkit-text-size-adjust:100%;-webkit-tap-highlight-color:transparent}
  body{height:100%;font-family:'DM Mono',monospace;background:#f4f4f2;overscroll-behavior:none;-webkit-font-smoothing:antialiased}
  #root{height:100%}
  ::-webkit-scrollbar{width:4px;height:4px}
  ::-webkit-scrollbar-track{background:#f4f4f2}
  ::-webkit-scrollbar-thumb{background:#ccc;border-radius:2px}
  input[type=number]::-webkit-inner-spin-button{opacity:0}
  input:focus,select:focus,textarea:focus{outline:none;border-color:#1a1a1a!important}
  .fu{animation:fadeUp .35s ease forwards}
  @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .safe-b{padding-bottom:calc(8px + env(safe-area-inset-bottom))}
`;

const ACT_LEVELS = {
  sedentary: { label: "座位中心", factor: 1.2 },
  light: { label: "軽い運動（週1〜2回）", factor: 1.375 },
  moderate: { label: "中程度（週3〜5回）", factor: 1.55 },
  active: { label: "激しい運動（週6〜7回）", factor: 1.725 },
  veryActive: { label: "毎日の激しい運動", factor: 1.9 },
};

const MOCK_DATA = [
  { date: "2026/01/26", weight: 77.0, fat: 22.5, hicarb: false },
  { date: "2026/01/27", weight: 76.8, fat: 22.4, hicarb: false },
  // ... (モックデータは必要に応じて追加してください)
];

/* ==========================================
   2. Utilities (Pure Functions)
========================================== */
const Utils = {
  calcBMR: (weight, height, age, sex) =>
    sex === "male"
      ? 10 * weight + 6.25 * height - 5 * age + 5
      : 10 * weight + 6.25 * height - 5 * age - 161,
      
  calcTDEE: (bmr, actLevel) => bmr * (ACT_LEVELS[actLevel]?.factor ?? 1.55),
  
  calcPFC: (tdee, goal, leanMass, pPct = 30, fPct = 25, customCal = "") => {
    let cal = tdee;
    if (goal === "cut") cal = tdee - 500;
    else if (goal === "bulk") cal = tdee + 300;
    else if (goal === "custom" && customCal) {
      const n = parseFloat(customCal);
      if (!isNaN(n)) cal = tdee + n;
    }
    const p = pPct ? (cal * pPct) / 100 / 4 : leanMass ? leanMass * 2.2 : (cal * 0.3) / 4;
    const f = fPct ? (cal * fPct) / 100 / 9 : (cal * 0.25) / 9;
    const c = Math.max(0, (cal - p * 4 - f * 9) / 4);
    
    return {
      calories: Math.round(cal),
      protein: Math.round(p),
      fat: Math.round(f),
      carbs: Math.round(c),
    };
  },
  
  calcBMI: (weight, height) => weight / (height / 100) ** 2,
  
  formatDate: (d) => `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, "0")}/${String(d.getDate()).padStart(2, "0")}`,
  
  parseDateString: (ds) => {
    if (!ds) return new Date();
    const p = ds.split("/");
    return p.length === 3 ? new Date(parseInt(p[0]), parseInt(p[1]) - 1, parseInt(p[2])) : new Date();
  },
  
  injectStyles: () => {
    if (typeof document === "undefined") return;
    if (!document.getElementById("dlp-global-styles")) {
      const style = document.createElement("style");
      style.id = "dlp-global-styles";
      style.textContent = GLOBAL_CSS;
      document.head.appendChild(style);
    }
  }
};

/* ==========================================
   3. Custom Hooks (State & Business Logic)
========================================== */
function useDietState() {
  const [isLoaded, setIsLoaded] = useState(false);

  // Grouped States
  const [profile, setProfile] = useState({
    height: "170", age: "30", sex: "male", activity: "moderate",
    goal: "cut", goalCustom: "", weight: ""
  });
  const [logs, setLogs] = useState(MOCK_DATA);
  const [settings, setSettings] = useState({ calcMode: "auto", macroView: "pct" });
  const [uiState, setUiState] = useState({ activeTab: "dashboard", modal: null });

  // Input states (Transient)
  const [todayInput, setTodayInput] = useState({ weight: "", fat: "" });

  // 1. Initial Load from LocalStorage
  useEffect(() => {
    try {
      const saved = localStorage.getItem(LS_KEY);
      if (saved) {
        const parsed = JSON.parse(saved);
        if (parsed.profile) setProfile(parsed.profile);
        if (parsed.logs) setLogs(parsed.logs);
        if (parsed.settings) setSettings(parsed.settings);
      }
    } catch (e) {
      console.error("Failed to load state", e);
    }
    setIsLoaded(true);
  }, []);

  // 2. Debounced Auto-Save to LocalStorage
  useEffect(() => {
    if (!isLoaded) return;
    const timer = setTimeout(() => {
      const stateToSave = { profile, logs, settings };
      localStorage.setItem(LS_KEY, JSON.stringify(stateToSave));
    }, 500); // 500msのデバウンスでパフォーマンスを最適化
    
    return () => clearTimeout(timer);
  }, [profile, logs, settings, isLoaded]);

  // 3. Derived Data (Memoized for performance)
  const derivedData = useMemo(() => {
    const latestLog = [...logs].reverse().find(d => d.weight !== null) || {};
    const currentWeight = parseFloat(profile.weight) || latestLog.weight || 75;
    const currentFat = latestLog.fat || 20;
    
    const heightNum = parseFloat(profile.height) || 170;
    const ageNum = parseFloat(profile.age) || 30;
    const leanMass = currentWeight * (1 - currentFat / 100);
    
    const bmr = Utils.calcBMR(currentWeight, heightNum, ageNum, profile.sex);
    const tdee = Utils.calcTDEE(bmr, profile.activity);
    const pfcTargets = Utils.calcPFC(tdee, profile.goal, leanMass);

    return {
      currentWeight, currentFat, leanMass, bmr, tdee, pfcTargets
    };
  }, [profile, logs]);

  // 4. Actions
  const recordToday = useCallback(() => {
    const { weight, fat } = todayInput;
    if (!weight && !fat) return;
    
    const todayStr = Utils.formatDate(new Date());
    setLogs(prev => {
      const existingIdx = prev.findIndex(d => d.date === todayStr);
      const newEntry = {
        date: todayStr,
        weight: weight ? parseFloat(weight) : null,
        fat: fat ? parseFloat(fat) : null,
        hicarb: false
      };
      
      if (existingIdx >= 0) {
        const updated = [...prev];
        updated[existingIdx] = { ...updated[existingIdx], ...newEntry };
        return updated;
      }
      return [...prev, newEntry].sort((a, b) => a.date.localeCompare(b.date));
    });
    
    setTodayInput({ weight: "", fat: "" });
  }, [todayInput]);

  return {
    profile, setProfile,
    logs, setLogs,
    settings, setSettings,
    uiState, setUiState,
    todayInput, setTodayInput,
    derivedData,
    actions: { recordToday }
  };
}

