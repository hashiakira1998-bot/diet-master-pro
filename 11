                    <input type="text" inputMode="numeric" value={prof[f.k]} onChange={(e) => setProf((p) => ({ ...p, [f.k]: e.target.value.replace(/[^0-9]/g, "") }))} style={{ ...IB, fontWeight: 700 }} />
