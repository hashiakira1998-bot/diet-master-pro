  const clearManualSlot = (i) => setManualMeals((prev) => prev.map((m, j) => (j === i ? { ...m, p: "", f: "", c: "" } : m)));
  const clearManualExtra = (i) => setManualExtra((prev) => prev.map((m, j) => (j === i ? { ...m, p: "", f: "", c: "" } : m)));
  const clearSemiSlot = (i) => setSemiMeals((prev) => prev.map((m, j) => (j === i ? { ...m, p: "", f: "", c: "" } : m)));

  const toFoodGram = (grams, per100) => {
    const p = parseFloat(per100);
    if (!p || p <= 0) return "—";
    return Math.round((grams / p) * 100);
  };

  /* Projection Vars */
  const SW = parseFloat(startWeight) || W;
  const TW = gw;
  const sdObj = parseISO(startDate);
  const tdObj = parseISO(gd);
  const totalDays = Math.max(1, daysBtwn(sdObj, tdObj));
  const dailySlope = (TW - SW) / totalDays;
  const totalLoss = SW - TW;
  const lossPerMonth = (totalLoss / (totalDays / 30)).toFixed(2);
  const lossPerWeek = (totalLoss / (totalDays / 7)).toFixed(2);

  const computeGoalLine = (arr) => {
    if (paceMode === "custom") {
      const pv = parseFloat(customPace) || 0.75;
      const sign = customDirection === "cut" ? -1 : 1;
      const dp = (pv / 7) * sign;
      return arr.map((d) => {
        const dDate = parseDate(d.date);
        const dfs = daysBtwn(sdObj, dDate);
        return SW + dp * dfs;
      });
    }
    return arr.map((d) => {
      const dDate = parseDate(d.date);
      const dfs = daysBtwn(sdObj, dDate);
      return SW + dailySlope * dfs;
    });
  };

  /* ═══ ADVISOR Calcs ═══ */
  const advisorKcalNum = parseFloat(advisorCalKcal) || 0;
  const advisorSWNum = parseFloat(advisorCalSW) || 0;
  const advisorGWNum = parseFloat(advisorCalGW) || 0;
  const advisorCalWarning = (() => {
    if (advisorCalDir === "cut") {
      if (advisorKcalNum <= 0) return null;
      if (advisorKcalNum <= 799) return null;
      if (advisorKcalNum <= 999) return { color: "#f4a261", msg: "筋肉の分解が強まり、停滞期が早期に来る可能性があります。" };
      return { color: "#e63946", msg: "基礎代謝を割り込んでいませんか?代謝低下、ホルモンバランスの乱れ、筋肉の著しい減少が起こってしまいます。" };
    } else {
      if (advisorKcalNum <= 500) return null;
      return { color: "#f4a261", msg: "トレーニングなしで500kcalプラス: ほぼ脂肪として蓄積されます。但し、ハードなトレーニングを含む場合は比率を筋肉に寄せることは可能です。" };
    }
  })();
  
  const advisorArrivalDate = (() => {
    if (!advisorCalStart || !advisorSWNum || !advisorGWNum || advisorKcalNum <= 0) return null;
    const weightDiff = Math.abs(advisorSWNum - advisorGWNum);
    if (weightDiff <= 0) return null;
    const kcalNeeded = weightDiff * 7200;
    const daysNeeded = Math.round(kcalNeeded / advisorKcalNum);
    const base = parseISO(advisorCalStart);
    const arrival = new Date(base);
    arrival.setDate(arrival.getDate() + daysNeeded);
    return arrival;
  })();

  const advisorTdeeHn = parseFloat(advisorTdeeH) || 0;
  const advisorTdeeAn = parseFloat(advisorTdeeA) || 0;
  const advisorTdeeWn = parseFloat(advisorTdeeW) || 0;
  const advisorBmr = (advisorTdeeHn && advisorTdeeAn && advisorTdeeWn)
    ? calcBMR(advisorTdeeWn, advisorTdeeHn, advisorTdeeAn, advisorTdeeSex) : 0;
  const advisorTdee = advisorBmr ? Math.round(advisorBmr * ACT[advisorTdeeAf].factor) : 0;

  const advisorDeficitRanges = advisorTdee > 0 ? {
    greenMax: Math.round(advisorTdee * 0.15),
    yellowMax: Math.round(advisorTdee * 0.25),
    redMax: Math.round(advisorTdee * 0.35)
  } : null;

  const advisorDeficitStatus = (() => {
    if (!advisorDeficitRanges || advisorKcalNum <= 0 || advisorCalDir !== "cut") return null;
    const { greenMax, yellowMax, redMax } = advisorDeficitRanges;
    if (advisorKcalNum < greenMax) return { status: "Green", dot: "🟢", label: "緑色（安全・推奨）", msg: `理想的なペースです！\n筋肉量とパフォーマンスを維持しながら、体脂肪のみを狙える最も安全な減量幅です。このままPFCバランスをキープしましょう。`, color: "#2a9d8f", borderColor: "#2a9d8f" };
    if (advisorKcalNum < yellowMax) return { status: "Yellow", dot: "🟡", label: "黄色（注意）", msg: `⚠️ 赤字幅がやや過剰です\n減量スピードは上がりますが、筋分解（カタボリック）のリスクが出始めています。十分なタンパク質摂取と強度のあるトレーニングを意識してください。`, color: "#f4a261", borderColor: "#f4a261" };
    if (advisorKcalNum < redMax) return { status: "Red", dot: "🔴", label: "赤色（危険）", msg: `🛑 危険な減量幅に達しています\n体が飢餓状態を察知し、筋肉の著しい減少やホルモンバランスの乱れ、代謝低下（停滞期）を招くリスクが極めて高いです。速やかにカロリーを引き上げてください。`, color: "#e63946", borderColor: "#e63946" };
    return { status: "Purple", dot: "🟣", label: "紫色（即時中止）", msg: `🚨 【警告】今すぐ食事制限の緩和を！\n基礎代謝を割り込む致命的なエネルギー不足です。体脂肪の減少は止まり、筋肉の分解（重度のカタボリック）や免疫力低下を引き起こします。安全なカロリー幅まで戻してください。`, color: "#9b59b6", borderColor: "#9b59b6" };
  })();

  const calcGeometricBand = (W_start, P, t) => W_start * Math.pow(1 - P / 7, t);
  
  const customArrivalDate = (() => {
    if (paceMode !== "custom") return null;
    const pv = parseFloat(customPace) || 0;
    if (pv <= 0) return null;
    const diff = Math.abs(SW - TW);
    const weeksNeeded = diff / pv;
    const daysNeeded = Math.round(weeksNeeded * 7);
    const arrival = new Date(sdObj);
    arrival.setDate(arrival.getDate() + daysNeeded);
    return arrival;
  })();

  const customPaceWarning = (() => {
    if (paceMode !== "custom" || customDirection !== "cut") return false;
    const pv = parseFloat(customPace) || 0;
    const maxWeeklyKg = W * 0.01;
    return pv > maxWeeklyKg;
  })();

  const computeIssnLine = (arr) => arr.map((d) => {
    const dDate = parseDate(d.date);
    const dfs = Math.max(0, daysBtwn(sdObj, dDate));
    return SW * Math.pow(1 - 0.007, dfs / 7);
  });
  
  const computeIssnUpper = (arr) => arr.map((d) => {
    const dDate = parseDate(d.date);
    const dfs = Math.max(0, daysBtwn(sdObj, dDate));
    return SW * Math.pow(1 - 0.005, dfs / 7);
  });
  
  const computeIssnLower = (arr) => arr.map((d) => {
    const dDate = parseDate(d.date);
    const dfs = Math.max(0, daysBtwn(sdObj, dDate));
    return SW * Math.pow(1 - 0.010, dfs / 7);
  });

  const goalWeightsFull = computeGoalLine(data);
  const issnWeightsFull = computeIssnLine(data);
  const issnUpperFull = computeIssnUpper(data);
  const issnLowerFull = computeIssnLower(data);
  const showIssnLine = !(paceMode === "custom" && customDirection === "bulk");

  const getCurrentTargetPace = () => {
    const bmi = calcBMI(W, heightNum);
    if (paceMode === "auto") return bmi >= 25 ? 0.75 : 0.5;
    return parseFloat(customPace) || 0.75;
  };

  const getWeekData = (offset) => {
    const today = new Date();
    const refDate = new Date(today);
    refDate.setDate(today.getDate() + offset * 7);
    const { start, end } = getWeekRange(refDate);
    const startStr = fmtDS(start);
    const endStr = fmtDS(end);
    const weekData = data.filter((d) => d.date >= startStr && d.date <= endStr);
    return { start, end, startStr, endStr, data: weekData };
  };

  const calcWeeklyLossRate = (weekData) => {
    const sorted = weekData.filter((d) => d.weight !== null).sort((a, b) => a.date.localeCompare(b.date));
    if (sorted.length < 3) return null;
    const firstDate = parseDate(sorted[0].date);
    const n = sorted.length;
    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
    sorted.forEach((d) => {
      const x = daysBtwn(firstDate, parseDate(d.date));
      const y = d.weight;
      sumX += x; sumY += y; sumXY += x * y; sumX2 += x * x;
    });
    const denom = n * sumX2 - sumX * sumX;
    if (denom === 0) return null;
    const slope = (n * sumXY - sumX * sumY) / denom;
    const weeklyChange = slope * 7;
    const avgWeight = sumY / n;
    const pctLoss = (-weeklyChange / avgWeight) * 100;
    const pace = -weeklyChange;
    return { pctLoss, pace };
  };

  const getWeeklyAdvice = (thisWeekData, lastWeekData) => {
    const thisResult = calcWeeklyLossRate(thisWeekData);
    if (!thisResult) return { color: "unknown", msg: "✅ データを蓄積中です。記録を続けましょう。", actualPace: null, status: "unknown" };
    
    const { pctLoss: thisPct, pace: thisPace } = thisResult;
    const lastResult = calcWeeklyLossRate(lastWeekData || []);
    const lastPct = lastResult ? lastResult.pctLoss : 0;
    const actualPace = thisPace;
    
    if (thisPct > 1.0) {
      if (lastPct > 1.0) return { color: "purple", msg: ADVICE_MSGS.purple[1], actualPace, status: "Purple" };
      else {
        const idx = Math.random() < 0.5 ? 0 : 2;
        return { color: "purple", msg: ADVICE_MSGS.purple[idx], actualPace, status: "Purple" };
      }
    }
    
    if (thisPct >= 0.40 && thisPct <= 1.0) {
      return { color: "green", msg: "✅ トレンドは順調な右肩下がりです。現在のPFCを維持しましょう。", actualPace, status: "Green" };
    }
    
    if (thisPct < 0.15 && lastPct < 0.15) {
      const wk = Math.min(consecutiveRed, 5);
      let idx;
      if (wk < 1) idx = Math.floor(Math.random() * 2);
      else if (wk < 2) idx = 2 + Math.floor(Math.random() * 2);
      else idx = Math.min(4 + (wk - 2), 5);
      return { color: "red", msg: ADVICE_MSGS.red[idx], actualPace, status: "Red" };
    }
    
    const wk = Math.min(consecutiveYellow, 5);
    let idx;
    if (wk < 1) idx = Math.floor(Math.random() * 2);
    else if (wk < 2) idx = 2 + Math.floor(Math.random() * 2);
    else idx = Math.min(4 + (wk - 2), 5);
    return { color: "yellow", msg: ADVICE_MSGS.yellow[idx], actualPace, status: "Yellow" };
  };

  const currentWeek = getWeekData(weekOffset);
  const lastWeek = getWeekData(weekOffset - 1);
  const wkD = currentWeek.data.length > 0 ? currentWeek.data : [{ date: fmtDS(currentWeek.start), weight: null, fat: null, hicarb: false }];
  const weekGoalLine = computeGoalLine(wkD);
  const weekIssnLine = computeIssnLine(wkD);
  const weekIssnUpper = computeIssnUpper(wkD);
  const weekIssnLower = computeIssnLower(wkD);
  const advice = getWeeklyAdvice(currentWeek.data, lastWeek.data);

  /* Style objects */
  const IB = { fontFamily: "'DM Mono',monospace", fontSize: 14, fontWeight: 500, color: "#1a1a1a", background: "#f8f8f6", border: "1px solid #e0e0de", borderRadius: 4, padding: "8px 12px", width: "100%", outline: "none" };
  const BP = { fontFamily: "'DM Mono',monospace", background: "#1a1a1a", color: "#fff", border: "none", borderRadius: 4, cursor: "pointer", fontWeight: 600 };
  const BS = { fontFamily: "'DM Mono',monospace", background: "#fff", color: "#3a3a3a", border: "1px solid #d0d0ce", borderRadius: 4, cursor: "pointer", fontWeight: 600 };
  const TABS = [{ id: "dashboard", l: "DASH" }, { id: "calc", l: "CALC" }, { id: "supps", l: "SUPPS" }, { id: "advisor", l: "ADVISOR" }];

  return (
    <div style={{ maxWidth: 540, margin: "0 auto", minHeight: "100%", display: "flex", flexDirection: "column", background: "#f4f4f2" }}>
