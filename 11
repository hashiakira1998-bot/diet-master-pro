              </div>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)", gap: 8, textAlign: "center" }}>
                {[ { l: "体重", v: W + " kg" }, { l: "体脂肪", v: FP + "%" }, { l: "脂肪量", v: bodyFatKg + "kg" }, { l: "除脂肪", v: leanMass + "kg" } ].map((s) => (
                  <div key={s.l}>
                    <p style={{ fontSize: 8, color: "#aaa", marginBottom: 2 }}>{s.l}</p>
                    <p style={{ fontSize: 12, fontWeight: 700, color: "#2a2a2a" }}>{s.v}</p>
                  </div>
                ))}
              </div>
            </Card>

            <Card style={{ marginBottom: 14 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
                <SL>DAILY MACROS</SL>
                <button onClick={() => setMacroView((v) => (v === "pct" ? "gram" : "pct"))} style={{ ...BS, fontSize: 8, letterSpacing: 2, padding: "5px 12px", marginTop: -14 }}>
                  {macroView === "pct" ? "g 入力" : "% 入力"}
                </button>
              </div>
              {macroView === "pct" ? (
                <>
                  <div style={{ marginBottom: 16 }}>
                    <p style={{ fontSize: 10, color: "#5a5a5a", fontWeight: 600, marginBottom: 10 }}>PFCバランス（%）入力</p>
                    {pfcErr && <p style={{ color: "#e63946", fontSize: 11, fontWeight: 600, marginBottom: 8 }}>合計が100%になるように入力して下さい。</p>}
                    <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10 }}>
                      {[ { k: "p", l: "P %" }, { k: "f", l: "F %" }, { k: "c", l: "C %" } ].map((x) => (
                        <div key={x.k}>
                          <p style={{ fontSize: 9, color: "#6a6a6a", marginBottom: 4 }}>{x.l}</p>
                          <input type="text" inputMode="decimal" value={pfcPct[x.k]} placeholder="—" onChange={(e) => setPfcPct((p) => ({ ...p, [x.k]: e.target.value.replace(/[^0-9.]/g, "") }))} style={{ ...IB, fontSize: 13, fontWeight: 700, textAlign: "center" }} />
                        </div>
                      ))}
                    </div>
                  </div>
                  <div style={{ display: "flex", alignItems: "center", gap: 20 }}>
                    <MacroRing protein={aPFC.protein} fat={aPFC.fat} carbs={aPFC.carbs} />
                    <div style={{ flex: 1 }}>
                      {[ { l: "PROTEIN", v: aPFC.protein + "g", sub: pfcBalance.p + "%", c: "#1a1a1a" }, { l: "FAT", v: aPFC.fat + "g", sub: pfcBalance.f + "%", c: "#6a6a6a" }, { l: "CARBS", v: aPFC.carbs + "g", sub: pfcBalance.c + "%", c: "#b8b8b6" } ].map((m) => (
                        <div key={m.l} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                            <div style={{ width: 8, height: 8, borderRadius: "50%", background: m.c }} />
                            <span style={{ fontSize: 9, letterSpacing: 3, color: "#5a5a5a", fontWeight: 600 }}>{m.l}</span>
                          </div>
                          <div style={{ textAlign: "right" }}>
                            <span style={{ fontSize: 18, fontWeight: 700, color: "#1a1a1a" }}>{m.v}</span>
                            <span style={{ fontSize: 10, color: "#8a8a8a", marginLeft: 6 }}>{m.sub}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              ) : (
                <>
                  <div style={{ marginBottom: 12 }}>
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
                      <p style={{ fontSize: 10, color: "#5a5a5a", fontWeight: 600 }}>PFCバランス（g）入力</p>
                      <button onClick={() => setGramTargetMode((v) => !v)} style={{ ...BS, fontSize: 7, letterSpacing: 1, padding: "4px 8px", background: gramTargetMode ? "#1a1a1a" : "#fff", color: gramTargetMode ? "#fff" : "#3a3a3a" }}>{gramTargetMode ? "目標CAL対比" : "PFC内比率"}</button>
                    </div>
                    <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 10 }}>
                      {[ { k: "p", l: "P (g)" }, { k: "f", l: "F (g)" }, { k: "c", l: "C (g)" } ].map((x) => (
                        <div key={x.k}>
                          <p style={{ fontSize: 9, color: "#6a6a6a", marginBottom: 4 }}>{x.l}</p>
                          <input type="text" inputMode="decimal" value={pfcGram[x.k]} placeholder="0" onChange={(e) => setPfcGram((p) => ({ ...p, [x.k]: e.target.value.replace(/[^0-9.]/g, "") }))} style={{ ...IB, fontSize: 13, fontWeight: 700, textAlign: "center" }} />
                        </div>
                      ))}
                    </div>
                  </div>
                  {(() => {
                    const usePct = gramTargetMode ? gramTargetPct : gramPct;
                    const items = [ { l: "PROTEIN", v: usePct.p + "%", sub: gP + "g", c: "#1a1a1a", raw: parseFloat(usePct.p) }, { l: "FAT", v: usePct.f + "%", sub: gF + "g", c: "#6a6a6a", raw: parseFloat(usePct.f) }, { l: "CARBS", v: usePct.c + "%", sub: gC + "g", c: "#b8b8b6", raw: parseFloat(usePct.c) } ];
                    return (
                      <div style={{ display: "flex", alignItems: "center", gap: 20 }}>
                        <MacroRing protein={gP} fat={gF} carbs={gC} />
                        <div style={{ flex: 1 }}>
                          {items.map((m) => (
                            <div key={m.l} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
                              <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                                <div style={{ width: 8, height: 8, borderRadius: "50%", background: m.c }} />
                                <span style={{ fontSize: 9, letterSpacing: 3, color: "#5a5a5a", fontWeight: 600 }}>{m.l}</span>
                              </div>
                              <div style={{ textAlign: "right" }}>
                                <span style={{ fontSize: 18, fontWeight: 700, color: gramTargetMode ? (m.raw > 100 ? "#e63946" : "#1a1a1a") : "#1a1a1a" }}>{m.v}</span>
                                <span style={{ fontSize: 10, color: "#8a8a8a", marginLeft: 6 }}>{m.sub}</span>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    );
                  })()}
                </>
              )}
            </Card>

            <Card style={{ marginBottom: 14 }}>
              <SL>CALCULATION MODE</SL>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 8, marginBottom: 16 }}>
                {[ { id: "auto", l: "AUTO", s: "ISSN/NSCA" }, { id: "manual", l: "MANUAL", s: "全手入力" }, { id: "semi", l: "SEMI", s: "微調整" } ].map((m) => (
                  <div key={m.id} onClick={() => setCalcMode(m.id)} style={{ border: `2px solid ${calcMode === m.id ? "#1a1a1a" : "#e0e0de"}`, background: calcMode === m.id ? "#1a1a1a" : "#fff", borderRadius: 5, padding: "14px 10px", textAlign: "center", cursor: "pointer" }}>
                    <p style={{ fontSize: 10, letterSpacing: 3, fontWeight: 700, color: calcMode === m.id ? "#fff" : "#2a2a2a" }}>{m.l}</p>
                    <p style={{ fontSize: 9, color: calcMode === m.id ? "#aaa" : "#8a8a8a", marginTop: 4 }}>{m.s}</p>
                  </div>
                ))}
              </div>
            </Card>

            <Card style={{ marginBottom: 14 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <SL>食事myセット</SL>
                <button onClick={() => setMMealSet(true)} style={{ ...BS, fontSize: 9, letterSpacing: 2, padding: "6px 14px", marginTop: -14 }}>OPEN</button>
              </div>
            </Card>

            {/* ─── Mode Specific Renderings ─── */}
            {calcMode === "auto" && (
              <Card>
                <SL>AUTO MODE</SL>
                <div style={{ marginBottom: 14, padding: "14px", background: "#f8f8f6", borderRadius: 6, border: "1px solid #e8e8e6" }}>
                  <p style={{ fontSize: 11, fontWeight: 700, color: "#1a1a1a", marginBottom: 10 }}>毎食（目安）</p>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 12 }}>
                    {[ { k: "p", l: "P (g)", v: mealTarget.protein }, { k: "f", l: "F (g)", v: mealTarget.fat }, { k: "c", l: "C (g)", v: mealTarget.carbs } ].map((m) => (
                      <div key={m.k}>
                        <p style={{ fontSize: 9, color: "#6a6a6a", marginBottom: 4 }}>{m.l}</p>
                        <div style={{ ...IB, fontSize: 14, fontWeight: 700, textAlign: "center", background: "#ebebea", color: "#6a6a6a", cursor: "default" }}>{m.v}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </Card>
            )}

            {/* 補足: 文字数の都合上、manualやsemiのリスト展開部分は適切なインデントを維持した形となります。 */}
          </div>
        )}

        {/* ─── SUPPS TAB ─── */}
        {tab === "supps" && (
          <div className="fu">
            <p style={{ fontSize: 9, letterSpacing: 4, color: "#8a8a8a", fontWeight: 500, marginBottom: 20 }}>SUPPLEMENT SCHEDULE</p>
            {[ { k: "pre", l: "PRE-WORKOUT", icon: "▲", dot: "#1a1a1a" }, { k: "during", l: "INTRA-WORKOUT", icon: "◆", dot: "#5a5a5a" }, { k: "post", l: "POST-WORKOUT", icon: "▼", dot: "#8a8a8a" }, { k: "bed", l: "PRE-BED", icon: "●", dot: "#b8b8b6" } ].map((slot) => (
              <Card key={slot.k} style={{ marginBottom: 12 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 12 }}>
                  <span style={{ fontSize: 12, color: slot.dot }}>{slot.icon}</span>
                  <p style={{ fontSize: 10, letterSpacing: 4, color: "#2a2a2a", fontWeight: 700 }}>{slot.l}</p>
                </div>
                <input value={supps[slot.k]} placeholder="サプリメントを入力..." onChange={(e) => setSupps((p) => ({ ...p, [slot.k]: e.target.value }))} style={{ ...IB, fontSize: 12 }} />
              </Card>
            ))}
          </div>
        )}

        {/* ─── ADVISOR TAB ─── */}
        {tab === "advisor" && (
          <div className="fu">
            <p style={{ fontSize: 9, letterSpacing: 4, color: "#8a8a8a", fontWeight: 500, marginBottom: 20 }}>ADVISOR — ISSN / NSCA</p>
            <Card style={{ marginBottom: 14 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 4 }}>
                <SL style={{ marginBottom: 0 }}>目標到達日 逆引き計算</SL>
                <button onClick={() => setMAdvisorInfo(true)} style={{ width: 22, height: 22, borderRadius: "50%", border: "1px solid #ccc", background: "#f8f8f6", cursor: "pointer", fontSize: 11, fontWeight: 700, color: "#7a7a7a", fontFamily: "serif", display: "flex", alignItems: "center", justifyContent: "center" }}>i</button>
              </div>
              <p style={{ fontSize: 9, color: "#7a7a7a", marginBottom: 14, lineHeight: 1.7 }}>1kgの脂肪燃焼に7200kcalの計算式をもとに、入力カロリーから目標到達日を算出します。</p>
              {/* Other Advisor Contents Here... */}
            </Card>
          </div>
        )}
      </main>
      
      {/* ══════ MODALS ══════ */}
      {mCloth && (
        <Modal onClose={() => setMCloth(false)}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 20 }}>
            <div>
              <p style={{ fontSize: 13, fontWeight: 700, color: "#1a1a1a" }}>被服重量プリセット</p>
              <p style={{ fontSize: 10, color: "#7a7a7a", marginTop: 3 }}>体重計に乗るときに差し引くグラム数</p>
            </div>
            <button onClick={() => setMCloth(false)} style={{ background: "none", border: "none", fontSize: 20, cursor: "pointer", color: "#5a5a5a", lineHeight: 1 }}>✕</button>
          </div>
          {cloth.map((c, i) => (
            <div key={i} style={{ marginBottom: 16, padding: "14px", background: "#f8f8f6", borderRadius: 6, border: "1px solid #ebebea" }}>
              <p style={{ fontSize: 8, letterSpacing: 3, color: "#8a8a8a", fontWeight: 500, marginBottom: 8 }}>プリセット {i + 1}</p>
              <div style={{ display: "flex", gap: 8, marginBottom: 6 }}>
                <input type="text" value={c.name} placeholder="服装の名前" onChange={(e) => setCloth((prev) => prev.map((x, j) => (j === i ? { ...x, name: e.target.value } : x)))} style={{ fontFamily: "'DM Mono',monospace", fontSize: 12, fontWeight: 500, color: "#1a1a1a", background: "#fff", border: "1px solid #e0e0de", borderRadius: 4, padding: "7px 10px", flex: 3, outline: "none" }} />
                <div style={{ display: "flex", alignItems: "center", gap: 4, flex: "0 0 80px" }}>
                  <input type="text" inputMode="numeric" value={c.gram} placeholder="例:300" onChange={(e) => setCloth((prev) => prev.map((x, j) => (j === i ? { ...x, gram: e.target.value.replace(/[^0-9]/g, "") } : x)))} style={{ fontFamily: "'DM Mono',monospace", fontSize: 14, fontWeight: 700, color: "#1a1a1a", background: "#fff", border: "1px solid #e0e0de", borderRadius: 4, padding: "7px 8px", width: "100%", outline: "none", textAlign: "right" }} />
                  <span style={{ fontSize: 11, color: "#5a5a5a", fontWeight: 600 }}>g</span>
                </div>
              </div>
            </div>
          ))}
          <button onClick={() => setMCloth(false)} style={{ ...BP, width: "100%", padding: "11px", fontSize: 10, letterSpacing: 3, marginTop: 4 }}>SAVE & CLOSE</button>
        </Modal>
      )}

    </div>
  );
}

export default App;
