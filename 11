  const aPFC = computeActiveCalories();
  const computeMealSetTotals = () => {
    if (!mealSets[curSetIdx]) return { p: 0, f: 0, c: 0, cal: 0 };
    let tp = 0, tf2 = 0, tc = 0;
    mealSets[curSetIdx].meals.forEach((m) => {
      tp += parseFloat(m.p) || 0;
      tf2 += parseFloat(m.f) || 0;
      tc += parseFloat(m.c) || 0;
    });
