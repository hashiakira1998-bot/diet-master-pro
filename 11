    ? { p: ((aPFC.protein * 4 / pfcTotal) * 100).toFixed(0), f: ((aPFC.fat * 9 / pfcTotal) * 100).toFixed(0), c: ((aPFC.carbs * 4 / pfcTotal) * 100).toFixed(0) }
    : { p: "0", f: "0", c: "0" };

  /* ═══ Gram-input PFC balance calc ═══ */
  const gP = parseFloat(pfcGram.p) || 0;
  const gF = parseFloat(pfcGram.f) || 0;
  const gC = parseFloat(pfcGram.c) || 0;
