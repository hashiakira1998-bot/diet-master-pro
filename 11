  const semiRemaining = { protein: aFC.protein - semiTotal.protein, fat: aFC.fat - semiTotal.fat, carbs: aFC.carbs - semiTotal.carbs };
  const remCal = semiRemaining.protein * 4 + semiRemaining.fat * 9 + semiRemaining.carbs * 4;

  const manualRemaining = { protein: aFC.protein - aPFC.protein, fat: aFC.fat - aPFC.fat, carbs: aFC.carbs - aPFC.carbs };
  const manualRemCal = manualRemaining.protein * 4 + manualRemaining.fat * 9 + manualRemaining.carbs * 4;

  const applyMealSet = (setIdx, mealIdx, mode, slotIdx) => {
    const src = mealSets[setIdx]?.meals[mealIdx];
    if (!src) return;
    if (mode === "manual") {
      const mLen = manualMeals.length;
      if (slotIdx < mLen) {
        setManualMeals((prev) => prev.map((m, j) => (j === slotIdx ? { ...m, p: src.p || "", f: src.f || "", c: src.c || "" } : m)));
      } else {
        const ei = slotIdx - mLen;
        setManualExtra((prev) => prev.map((m, j) => (j === ei ? { ...m, p: src.p || "", f: src.f || "", c: src.c || "" } : m)));
      }
    } else if (mode === "semi") {
      setSemiMeals((prev) => prev.map((m, j) => (j === slotIdx ? { ...m, p: src.p || "", f: src.f || "", c: src.c || "", locked: false } : m)));
    }
    setMSetPicker(null);
  };

  const applyBulkMealSet = (setIdx, mode) => {
    const src = mealSets[setIdx]?.meals;
    if (!src) return;
    if (mode === "manual") {
      setManualMeals((prev) => prev.map((m) => {
        const match = src.find((s) => s.label === m.label);
        return match ? { ...m, p: match.p || "", f: match.f || "", c: match.c || "" } : m;
      }));
      setManualExtra((prev) => prev.map((m) => {
        const match = src.find((s) => s.label === m.label);
        return match ? { ...m, p: match.p || "", f: match.f || "", c: match.c || "" } : m;
      }));
    } else if (mode === "semi") {
      setSemiMeals((prev) => prev.map((m) => {
        const match = src.find((s) => s.label === m.label);
        if (!match) return m;
        const hasVal = (parseFloat(match.p) || 0) > 0 || (parseFloat(match.f) || 0) > 0 || (parseFloat(match.c) || 0) > 0;
        return { ...m, p: match.p || "", f: match.f || "", c: match.c || "", locked: !hasVal };
