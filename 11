    ? { p: ((gP * 4 / gTotal) * 100).toFixed(1), f: ((gF * 9 / gTotal) * 100).toFixed(1), c: ((gC * 4 / gTotal) * 100).toFixed(1) }
    : { p: "0.0", f: "0.0", c: "0.0" };
    
  const tgtCal = aFC.calories || 1;
  const gramTargetPct = {
    p: ((gP * 4 / tgtCal) * 100).toFixed(1),
    f: ((gF * 9 / tgtCal) * 100).toFixed(1),
    c: ((gC * 4 / tgtCal) * 100).toFixed(1)
  };
  const gramTargetSum = parseFloat(gramTargetPct.p) + parseFloat(gramTargetPct.f) + parseFloat(gramTargetPct.c);

