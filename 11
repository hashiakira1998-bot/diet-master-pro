                <strong style={{ color: data.c }}>{data.v}g</strong>
              </div>
            ))}
          </div>
        </div>
      </Card>
    </div>
  );
};

const ProfileTab = ({ store }) => {
  const { profile, setProfile } = store;
  
  const handleProfileChange = (key, value) => {
