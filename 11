                   style={{ ...styles.inputBase, fontSize: 20, fontWeight: 700 }} />
          </div>
          <div style={{ flex: 1 }}>
            <p style={{ fontSize: 10, color: "#5a5a5a", fontWeight: 600, marginBottom: 6 }}>体脂肪率 (%)</p>
            <input type="text" inputMode="decimal" placeholder={derivedData.currentFat.toString()} 
                   value={todayInput.fat} onChange={e => setTodayInput(p => ({ ...p, fat: e.target.value.replace(/[^0-9.]/g, "") }))} 
                   style={{ ...styles.inputBase, fontSize: 20, fontWeight: 700 }} />
          </div>
          <button onClick={actions.recordToday} style={{ ...styles.btnPrimary, fontSize: 9, opacity: (todayInput.weight || todayInput.fat) ? 1 : 0.35 }}>
            記録
          </button>
        </div>
      </Card>

      <Card>
        <SectionLabel>DAILY MACROS (Auto)</SectionLabel>
        <div style={{ display: "flex", alignItems: "center", gap: 20 }}>
          <MacroRing protein={derivedData.pfcTargets.protein} fat={derivedData.pfcTargets.fat} carbs={derivedData.pfcTargets.carbs} />
          <div style={{ flex: 1 }}>
            {/* Displaying extracted calculation logic cleanly */}
            {Object.entries({
